# ═══════════════════════════════════════════════════════════
# MADE Environment Variables
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════

# ─── Server ──────────────────────────────────────────────
MADE_PORT=3000
MADE_HOST=0.0.0.0

# ─── Authentication (REQUIRED for production) ────────────
# Set a strong random token. All API and WebSocket requests
# will require ?token=<value> or Authorization: Bearer <value>
MADE_TOKEN=

# ─── CORS ────────────────────────────────────────────────
# Allowed origin for CORS headers. Leave empty for same-origin.
# Set to "*" only in development.
MADE_CORS_ORIGIN=

# ─── Project ─────────────────────────────────────────────
# Root directory for session worktrees
MADE_PROJECT_DIR=

# ─── Agent ───────────────────────────────────────────────
# Agent command: claude | opencode
MADE_AGENT_CMD=claude

# Set to "true" to allow Claude Code to skip permission prompts
# WARNING: This grants full filesystem/command access without confirmation
MADE_CLAUDE_UNSAFE=false

# ─── Data ────────────────────────────────────────────────
# Directory for persistent data (sessions, users)
MADE_DATA_DIR=

# ─── Git Provider Tokens (for PR/MR creation) ───────────
# Uncomment and set the one matching your provider:
# GITHUB_TOKEN=
# GITLAB_TOKEN=
# GITEA_TOKEN=
# BITBUCKET_TOKEN=
# BITBUCKET_USER=
